{
  "Use all of module": {
    "prefix": "usemod",
    "body": [
      "mod $0;",
      "pub use $0::*;",
    ]
  },

  "Test Module": {
    "prefix": "tests",
    "body": [
      "#[cfg(test)]",
      "mod tests",
      "{",
      "\t#[test]",
      "\tfn ${1:test}()",
      "\t{",
      "\t\t$0",
      "\t}",
      "}",
    ]
  },
}